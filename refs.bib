% refs.bib
% 交通工学研究発表会講演集 参考文献サンプル
% jste.csl と組み合わせて使用します
%
% 使用方法（main.typ の参考文献セクション）:
%   #bibliography("refs.bib", style: "jste.csl", title: "参考文献")
%
% 本文中引用:
%   … である @kotsu2020。      % → 上付き 1) として出力
%
% ─── 著者名の記法 ────────────────────────────────────────────────────
%   和文：{{交通 太郎}} と二重波括弧で保護する（姓名分割を回避）
%   英文：{Smith, John} と「姓, 名」形式で記載する
%         複数著者は and でつなぐ（例：{Smith, John and Jones, Mary}）
%
% ─── 言語指定 ─────────────────────────────────────────────────────────
%   英文エントリには langid = {english} を付与する。
%   これにより CSL が英文向けのフォーマット（著者区切り ", "、
%   最終著者前に "and"）を自動選択する。
%   和文エントリは langid 不要（デフォルトで和文形式を適用）。
%
%   注意：langid は biblatex の拡張フィールドであり、Typst のバージョンや
%   hayagriva の実装によっては CSL language 変数にマップされない場合がある。
%   その場合、英文エントリでも和文形式（・区切り）で出力される。
%
% ─── 数値フィールドの注意 ─────────────────────────────────────────────
%   volume / number / pages / year は数値・標準フォーマットのみ受け付ける。
%   pages は {100--200} のように -- でページ範囲を示す。

% ------------------------------------------------------------------
% 和文：単行本（書式①）
%   著者名：単行本名，出版元，発表年．
% ------------------------------------------------------------------
@book{kotsu2020,
  author    = {{著者名}},
  title     = {単行本名},
  publisher = {出版元},
  year      = {2020},
}

% ------------------------------------------------------------------
% 和文：書籍の章・節（書式②）
%   著者名：担当箇所題目，単行本名（編著者名），出版元，開始-終了ページ，発表年．
% ------------------------------------------------------------------
@incollection{kogaku2019,
  author    = {{著者名}},
  title     = {担当箇所題目},
  booktitle = {単行本名},
  editor    = {{編著者名}},
  publisher = {出版元},
  pages     = {100--200},
  year      = {2019},
}

% ------------------------------------------------------------------
% 和文：雑誌論文（書式③）
%   著者名：論文題目，掲載誌名，Vol. x, No. x，開始-終了ページ，発表年．
%   volume = 巻、number = 号 に対応（例：7巻2号 → Vol. 7, No. 2）
% ------------------------------------------------------------------
@article{takebashi2021,
  author  = {{著者名}},
  title   = {論文題目},
  journal = {掲載誌名},
  volume  = {7},
  number  = {2},
  pages   = {1--10},
  year    = {2021},
}

% ------------------------------------------------------------------
% 和文：Webページ（書式④）
%   著者名：記事題目，Webサイト名，URL，発表年．（閲覧年月日）
%
%   @online 型を使用する。
%   サイト名は publisher フィールドに記載する（organization は
%   Typst 内部で CSL publisher 変数に正しくマップされないため）。
%   urldate は ISO 8601 形式（YYYY-MM-DD）で記載する。
% ------------------------------------------------------------------
@online{jste2023,
  author    = {{著者名}},
  title     = {記事題目},
  publisher = {Webサイト名},
  url       = {https://www.example.com/},
  year      = {2023},
  urldate   = {2024-03-01},
}

% ------------------------------------------------------------------
% 英文：雑誌論文の記載例（langid = {english} を付与）
%   Last, First: Title, Journal, Vol. x, No. x, pp, Year.
% ------------------------------------------------------------------
@article{wardrop1952,
  author  = {Wardrop, John Glen},
  title   = {Some theoretical aspects of road traffic research},
  journal = {Proceedings of the Institution of Civil Engineers},
  volume  = {1},
  number  = {3},
  pages   = {325--362},
  year    = {1952},
  langid  = {english},
}

% ------------------------------------------------------------------
% 英文：単行本の記載例
%   Last, First: Title, Publisher, Year.
% ------------------------------------------------------------------
@book{daganzo1997,
  author    = {Daganzo, Carlos F.},
  title     = {Fundamentals of Transportation and Traffic Operations},
  publisher = {Pergamon},
  year      = {1997},
  langid    = {english},
}
